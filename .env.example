# API 配置
models = ["gpt-image-1.5", "gemini-3-pro-image-preview-2k-vip", "nano-banana-2-2k-vip"]
base_url = https://api.tu-zi.com
api_keys = YOUR_API_KEY_HERE

# 端点映射
endpoint_map = {"nano-banana-2-2k-vip": "/v1/images/edits", "gpt-image-1.5": "/v1/images/generations", "gemini-3-pro-image-preview-2k-vip": "/v1/images/generations"}

# 数据库配置（可选）
host = your-db-host.com
port = 3306
user = "your_username"
password = "your_password"
